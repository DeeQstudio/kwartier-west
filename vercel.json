{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "kwartierwest.be"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://kwartierwest.be/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.kwartierwest.be"
        }
      ],
      "destination": "https://kwartierwest.be/:path*",
      "permanent": true
    },
    {
      "source": "/pages/hiphop/artist/:slug/index.html",
      "destination": "/pages/hiphop/artist/:slug",
      "permanent": true
    },
    {
      "source": "/pages/hiphop/artist/:slug/",
      "destination": "/pages/hiphop/artist/:slug",
      "permanent": true
    },
    {
      "source": "/pages/tekno/artist/:slug/index.html",
      "destination": "/pages/tekno/artist/:slug",
      "permanent": true
    },
    {
      "source": "/pages/tekno/artist/:slug/",
      "destination": "/pages/tekno/artist/:slug",
      "permanent": true
    },
    {
      "source": "/pages/events/detail/:slug/index.html",
      "destination": "/pages/events/detail/:slug",
      "permanent": true
    },
    {
      "source": "/pages/events/detail/:slug/",
      "destination": "/pages/events/detail/:slug",
      "permanent": true
    },
    {
      "source": "/pages/hiphop/artist.html",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "(?<slug>[^&]+)"
        }
      ],
      "destination": "/pages/hiphop/artist/:slug",
      "permanent": true
    },
    {
      "source": "/pages/tekno/artist.html",
      "has": [
        {
          "type": "query",
          "key": "slug",
          "value": "(?<slug>[^&]+)"
        }
      ],
      "destination": "/pages/tekno/artist/:slug",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/pages/:side(tekno|hiphop)/artist/:slug",
      "destination": "/pages/:side/artist/:slug/index.html"
    },
    {
      "source": "/pages/events/detail/:slug",
      "destination": "/pages/events/detail/:slug/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    }
  ]
}
